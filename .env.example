# Neatly — backend (Spring Boot)

# Spring does not load this file by default: use IDE env, `export`, Render dashboard,

# or `docker run --env-file`. Copy values from here; never commit a filled `.env`.

#

# Quick local run (in-memory DB + dev JWT): ./mvnw spring-boot:run uses profile "local" (see pom.xml).

# Production / real DB: do NOT set SPRING_PROFILES_ACTIVE=local; set SPRING_DATASOURCE_* + JWKS below.

# Full reference: docs/env.md



# --- Server (Render sets PORT automatically) ---

# PORT=



# Optional

# SPRING_APPLICATION_NAME=neatly-api



# --- Supabase Postgres (Settings → Database) ---

# Example: jdbc:postgresql://HOST:5432/postgres?sslmode=require

# Pooler: jdbc:postgresql://aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

SPRING_DATASOURCE_URL=

SPRING_DATASOURCE_USERNAME=postgres

SPRING_DATASOURCE_PASSWORD=



# --- Supabase API (Settings → API) ---

SUPABASE_URL=

# service_role — server only, never in frontend (maps to supabase.api-key)

SUPABASE_API_KEY=

# Override default bucket name if needed (default often set in application.properties)

# SUPABASE_BUCKET=Profile-Admin



# --- Verify Supabase Bearer JWTs (rule.md) ---

# Replace YOUR_PROJECT_REF with the host part of SUPABASE_URL (e.g. xxxx.supabase.co → xxxx)

SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1

SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# Profile "local" (default for ./mvnw spring-boot:run): if SUPABASE_JWKS_URL is empty, Spring uses HS256 with
# supabase.jwt.secret — application-local.properties defaults to a DEV-ONLY placeholder that is NOT your Supabase
# signing key. Real access_token from the browser will then get 401 on /api/v1/me.
# Fix for local + real Supabase Auth login:
#   (A) Set SUPABASE_JWKS_URL + SUPABASE_JWT_ISSUER above (works when your project uses asymmetric JWT / JWKS has keys), OR
#   (B) Leave SUPABASE_JWKS_URL unset and set SUPABASE_JWT_SECRET to the exact "JWT Secret" from
#       Supabase Dashboard → Settings → API (same secret used to sign user JWTs).
# Production: prefer JWKS + issuer; do not rely on symmetric secret in app config.



# --- Stripe ---

STRIPE_SECRET_KEY=

STRIPE_WEBHOOK_SECRET=



# --- Gemini (optional) ---

# GEMINI_API_KEY=



# --- CORS (optional; must match your CorsConfiguration property names) ---

# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173



# --- Logging (optional; Spring relaxed binding) ---

# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO

# LOGGING_LEVEL_COM_NEATLY=DEBUG

